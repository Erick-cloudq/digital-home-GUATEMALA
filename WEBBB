            orders: JSON.parse(localStorage.getItem('dh_orders') || '[]'),
            customProducts: JSON.parse(localStorage.getItem('dh_custom_products') || '[]'),
            deletedProductIds: JSON.parse(localStorage.getItem('dh_deleted_ids') || '[]'),
            currentRoute: 'home', searchQuery: '', selectedRating: 0, detailQty: 1
        };

        function getAllProducts() {
            let all = [...PRODUCTS_DATA, ...state.customProducts].filter(p => !state.deletedProductIds.includes(p.id));
            state.offers.forEach(o => {
                if (new Date(o.expiry) > new Date()) {
                    all = all.map(p => {
                        if (o.productId === 'all' || p.id === parseInt(o.productId) || p.cat === o.productId) {
                            const d = o.type === 'percent' ? p.price * (o.value / 100) : o.value;
                            return { ...p, originalPrice: p.price, price: Math.max(0, p.price - d), hasOffer: true, offerLabel: o.type === 'percent' ? `-${o.value}%` : `-Q${o.value}` };
                        } return p;
                    });
                }
            }); return all;
        }

        function saveState() {
            localStorage.setItem('dh_cart', JSON.stringify(state.cart));
            localStorage.setItem('dh_user', JSON.stringify(state.user));
            localStorage.setItem('dh_users', JSON.stringify(state.users));
            localStorage.setItem('dh_reviews', JSON.stringify(state.reviews));
            localStorage.setItem('dh_offers', JSON.stringify(state.offers));
            localStorage.setItem('dh_orders', JSON.stringify(state.orders));
            localStorage.setItem('dh_custom_products', JSON.stringify(state.customProducts));
            localStorage.setItem('dh_deleted_ids', JSON.stringify(state.deletedProductIds));
        }

        function navigateTo(route) { state.currentRoute = route; window.location.hash = route; renderApp(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
        window.addEventListener('hashchange', () => { state.currentRoute = window.location.hash.slice(1) || 'home'; renderApp(); });

        function showToast(msg, type = 'success') {
            const c = document.getElementById('toastContainer'), t = document.createElement('div');
            t.className = `toast toast-${type}`;
            const icons = { success: 'fa-check-circle', error: 'fa-exclamation-circle', info: 'fa-info-circle' };
            t.innerHTML = `<i class="fas ${icons[type]}"></i> ${msg}`;
            c.appendChild(t); setTimeout(() => { t.style.opacity = '0'; t.style.transform = 'translateX(100px)'; setTimeout(() => t.remove(), 300); }, 3000);
        }

        function addToCart(id, qty = 1) {
            const p = getAllProducts().find(x => x.id === id); if (!p) return;
            const e = state.cart.find(i => i.id === id);
            if (e) e.qty += qty; else state.cart.push({ id, qty });
            saveState(); updateCartBadge(); showToast(`${p.name} agregado al carrito`);
        }
        function removeFromCart(id) { state.cart = state.cart.filter(i => i.id !== id); saveState(); updateCartBadge(); if (state.currentRoute === 'cart') renderApp(); }
        function updateCartQty(id, d) { const i = state.cart.find(x => x.id === id); if (i) { i.qty += d; if (i.qty <= 0) { removeFromCart(id); return; } } saveState(); updateCartBadge(); if (state.currentRoute === 'cart') renderApp(); }
        function getCartTotal() { const p = getAllProducts(); return state.cart.reduce((s, i) => { const pr = p.find(x => x.id === i.id); return s + (pr ? pr.price * i.qty : 0); }, 0); }
        function updateCartBadge() { const b = document.getElementById('cartBadge'), t = state.cart.reduce((s, i) => s + i.qty, 0); if (t > 0) { b.classList.remove('hidden'); b.textContent = t; b.classList.add('bounce'); setTimeout(() => b.classList.remove('bounce'), 400); } else b.classList.add('hidden'); }

        function handleSearch(q) { state.searchQuery = q; if (q.length >= 2) navigateTo('search/' + encodeURIComponent(q)); else if (!q && state.currentRoute.startsWith('search')) navigateTo('home'); }

        function starsHTML(r) { let h = ''; for (let i = 1; i <= 5; i++) { if (i <= Math.floor(r)) h += '<i class="fas fa-star"></i>'; else if (i - 0.5 <= r) h += '<i class="fas fa-star-half-alt"></i>'; else h += '<i class="far fa-star"></i>'; } return `<span class="stars">${h}</span>`; }
        function getProductRating(id) { const r = state.reviews[id] || []; if (!r.length) return { avg: 0, count: 0 }; return { avg: r.reduce((s, x) => s + x.rating, 0) / r.length, count: r.length }; }

        function productCardHTML(p) {
            const cat = CATEGORIES.find(c => c.id === p.cat), r = getProductRating(p.id), d = (Math.random() * 0.3).toFixed(2);
            return `<div class="product-card" style="animation-delay:${d}s">
