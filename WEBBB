            const zones = [
                {lat:14.6349,lng:-90.5069,name:'Guatemala City',r:15000,color:'#27ae60',info:'Envío e instalación el mismo día'},
                {lat:14.6333,lng:-90.6167,name:'Mixco',r:8000,color:'#27ae60',info:'Envío inmediato'},
                {lat:14.5253,lng:-90.5872,name:'Villa Nueva',r:8000,color:'#27ae60',info:'Envío inmediato'},
                {lat:14.5586,lng:-90.7353,name:'Antigua Guatemala',r:10000,color:'#f39c12',info:'Envío 2-3 días'},
                {lat:14.6614,lng:-90.8164,name:'Chimaltenango',r:10000,color:'#f39c12',info:'Envío 2-3 días'},
                {lat:14.3050,lng:-90.7850,name:'Escuintla',r:12000,color:'#f39c12',info:'Envío 2-3 días'},
                {lat:14.8500,lng:-91.5167,name:'Quetzaltenango',r:15000,color:'#3498db',info:'Envío 3-5 días'},
                {lat:15.4833,lng:-90.3667,name:'Cobán',r:12000,color:'#3498db',info:'Envío 3-5 días'},
                {lat:14.8333,lng:-89.5333,name:'Chiquimula',r:10000,color:'#3498db',info:'Envío 3-5 días'},
                {lat:16.9167,lng:-89.8833,name:'Flores, Petén',r:15000,color:'#3498db',info:'Envío 3-5 días'},
                {lat:15.7333,lng:-88.6000,name:'Puerto Barrios',r:10000,color:'#3498db',info:'Envío 3-5 días'}
            ];
            zones.forEach(z => {
                L.circle([z.lat, z.lng], {radius:z.r, color:z.color, fillColor:z.color, fillOpacity:0.2, weight:2}).addTo(map).bindPopup(`<strong>${z.name}</strong><br>${z.info}`);
                L.marker([z.lat, z.lng]).addTo(map).bindPopup(`<strong>${z.name}</strong><br>${z.info}`);
