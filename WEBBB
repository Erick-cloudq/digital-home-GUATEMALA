        /* =========================================
   Íconos de Métodos de Pago
   ========================================= */
        .payment-methods-container {
            margin-top: 1.5rem;
        }

        .payment-methods-title {
            font-size: 0.85rem;
            font-weight: 700;
            color: rgba(255, 255, 255, 0.8);
            margin-bottom: 10px;
        }

        .payment-icons {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .payment-icons i {
            font-size: 32px;
            /* Tamaño de los logos */
            color: rgba(255, 255, 255, 0.5);
            /* Color grisáceo para que combine con tu footer oscuro */
            transition: all 0.3s ease;
        }

        /* Colores originales al pasar el mouse */
        .payment-icons i.fa-cc-visa:hover {
            color: #1a1f71;
            transform: translateY(-3px);
        }

        .payment-icons i.fa-cc-mastercard:hover {
            color: #eb001b;
            transform: translateY(-3px);
        }

        .payment-icons i.fa-cc-paypal:hover {
            color: #00457c;
            transform: translateY(-3px);
        }

        .payment-icons i.fa-money-bill-wave:hover {
            color: #34c759;
            transform: translateY(-3px);
        }

        /* =========================================
   Barra de Anuncios Superior (ACTUALIZADA)
   ========================================= */
        .top-announcement-bar {
            background-color: var(--accent-blue);
            color: #ffffff;
            text-align: center;
            padding: 10px 15px;
            font-size: 14px;
            font-weight: 500;
            width: 100%;
            z-index: 999999;
            /* Un número gigante para que el menú no la tape */
            position: fixed;
            /* La anclamos a la pantalla */
            top: 0;
            /* La pegamos al techo de la página */
            left: 0;
            letter-spacing: 0.5px;
        }

        /* Bajamos el menú y el cuerpo para que la barra azul no los tape a ellos */
        body {
            padding-top: 40px !important;
        }

        /* Ocultar barra en móviles si ocupa mucho espacio */
        @media (max-width: 480px) {
            .top-announcement-bar {
                font-size: 12px;
                padding: 8px 10px;
            }

            body {
                padding-top: 32px !important;
            }
        }

        /* =========================================
   Ajuste para que la barra azul no tape el menú
   ========================================= */
        .navbar {
            top: 40px !important;
            /* Empuja el menú hacia abajo para dejar espacio */
        }

        /* Ajuste para pantallas de celulares */
        @media (max-width: 480px) {
            .navbar {
                top: 32px !important;
            }
        }

